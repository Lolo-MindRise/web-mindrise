# Endpoint to which /api/contact forwards the contact form payload.
# In production, set this to a webhook URL (e.g. n8n, Zapier, Make, your own ingestion endpoint).
# The application performs a server-side POST with the form data — never expose this URL on the client.
CONTACT_WEBHOOK_URL=https://example.com/your-webhook-endpoint

# Optional: public site URL used by metadata, sitemap and JSON-LD.
# Defaults to https://mindrise-labs.com when unset.
NEXT_PUBLIC_SITE_URL=https://mindrise-labs.com
